# Copy to .env and fill values.
# For Docker Compose in this repo, this file is passed into rag-pipeline and rag-worker.

# -----------------------------------------------------------------------------
# REQUIRED FOR DEFAULT PIPELINE EXAMPLES / OPENAI EMBEDDINGS
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# Required by scripts/run_pipeline_examples.py (runner always sends Bearer token).
# API currently does not enforce auth, so any non-empty value works.
RAG_API_TOKEN=dev-token

# -----------------------------------------------------------------------------
# RAG-PIPELINE CORE SETTINGS (app/core/config.py)
# -----------------------------------------------------------------------------
# Docker defaults (service hostnames):
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/rag_api
REDIS_URL=redis://redis:6379/0
CELERY_ALWAYS_EAGER=false

APP_NAME=rag-api
APP_VERSION=0.3.0
API_PREFIX=/api/v1

CELERY_QUEUE_DEFAULT=rag-jobs
CELERY_QUEUE_MINERU=rag-mineru

MAX_ACTIVE_JOBS_PER_PROJECT=4
MAX_PLAYWRIGHT_JOBS=2
MAX_RETRIEVER_SESSIONS_PER_RETRIEVER=8
RETRIEVER_SESSION_TTL_SECONDS=3600

LOCAL_BLOB_ROOT=/data/blobstore
INDEX_STORAGE_ROOT=/data/indexes
NLTK_DATA=/data/nltk_data
BLOB_BACKEND=filesystem
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=rag-artifacts

RAG_LIB_SOURCE_DIR=/opt/rag-lib/src/rag_lib
RAG_LIB_EXAMPLES_DIR=/opt/rag-lib/examples
PLUGIN_REGISTRY_FILE=./config/plugins.json

# -----------------------------------------------------------------------------
# RAG-LIB GLOBAL + PROVIDER SETTINGS (C:/Projects/rag-lib/src/rag_lib/config.py)
# -----------------------------------------------------------------------------
# Nested settings prefixes:
LLM_PROVIDER=openai
LLM_MODEL=base
LLM_TEMPERATURE=0.0

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small

VECTOR_PROVIDER=chroma
VECTOR_COLLECTION_NAME=rag_lib_collection
VECTOR_PATH=/data/indexes/chroma
# VECTOR_URL=
# VECTOR_API_KEY=

GRAPH_PROVIDER=networkx
# GRAPH_URI=bolt://neo4j:7687
# GRAPH_USERNAME=neo4j
# GRAPH_PASSWORD=neo4j_password
GRAPH_DATABASE=neo4j

INGEST_CHUNK_SIZE=100
INGEST_SEMANTIC_THRESHOLD=0.6
INGEST_DEFAULT_PDF_BACKEND=poppler

# Optional; keep default unless you need custom prompt text.
# PROMPT_TABLE_SUMMARIZER_TEMPLATE=
PROMPT_TABLE_SUMMARIZER_SOFT_MAX_CHARS=700

# rag-lib top-level API keys:
# OPENAI_API_KEY_PERSONAL=
# MISTRAL_API_KEY=
# YA_API_KEY=
# YA_FOLDER_ID=

# -----------------------------------------------------------------------------
# OPTIONAL NETWORK/PROXY (used by some loaders, e.g. MinerU downloads)
# -----------------------------------------------------------------------------
# HTTP_PROXY=
# HTTPS_PROXY=
# ALL_PROXY=
